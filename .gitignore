# Ignorar archivos de configuración sensibles
.env
.env.local
.env.*.local

# Ignorar logs
logs/
*.log

# Ignorar archivos cargados
backend/uploads/*
!backend/uploads/.gitkeep
uploads/*
!uploads/.gitkeep

# Ignorar dependencias
vendor/
node_modules/
backend/node_modules/
frontend/node_modules/

# Ignorar builds generados
dist/
frontend/dist/
backend/dist/

# Ignorar archivos generados por herramientas
coverage/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignorar caché
.cache/
temp/

# Ignorar archivos del sistema
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Ignorar IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Ignorar archivos de prueba
test/
tests/

# Ignorar archivos temporales
.tmp/
.temp/
